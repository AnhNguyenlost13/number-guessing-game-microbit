ext\"><shadow type=\"text\"><field name=\"TEXT\">X</field></shadow></value><next><block type=\"device_show_number\"><value name=\"number\"><block type=\"variables_get\"><field name=\"VAR\" id=\"G6D64Yar|P.lB[Mt,b0l\">streak</field></block></value></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":"","main.py":"score = 0\nstreak = 0\nbest_score = 0\nbest_streak = 0\npoints = 0\n\nguess = 5\ntarget = 0\nlast_target = -1\nattempts_left = 4\nmax_guess = 9\nrange_unlocked = False\n\n\ndef wait_for_release():\n    basic.pause(80)\n    while input.button_is_pressed(Button.AB):\n        basic.pause(20)\n    while input.button_is_pressed(Button.A):\n        basic.pause(20)\n    while input.button_is_pressed(Button.B):\n        basic.pause(20)\n\n\ndef draw_attempts_left():\n    led.plot_brightness(0, 0, 8)\n    led.plot_brightness(0, 1, 8)\n    led.plot_brightness(0, 2, 8)\n    led.plot_brightness(0, 3, 8)\n    led.plot_brightness(0, 4, 8)\n\n    if attempts_left >= 1:\n        led.plot_brightness(0, 4, 120)\n    if attempts_left >= 2:\n        led.plot_brightness(0, 3, 120)\n    if attempts_left >= 3:\n        led.plot_brightness(0, 2, 120)\n    if attempts_left >= 4:\n        led.plot_brightness(0, 1, 120)\n\n\ndef draw_attempts_right():\n    led.plot_brightness(4, 0, 8)\n    led.plot_brightness(4, 1, 8)\n    led.plot_brightness(4, 2, 8)\n    led.plot_brightness(4, 3, 8)\n    led.plot_brightness(4, 4, 8)\n\n    if attempts_left >= 1:\n        led.plot_brightness(4, 4, 120)\n    if attempts_left >= 2:\n        led.plot_brightness(4, 3, 120)\n    if attempts_left >= 3:\n        led.plot_brightness(4, 2, 120)\n    if attempts_left >= 4:\n        led.plot_brightness(4, 1, 120)\n\n\ndef draw_streak_right():\n    led.plot_brightness(4, 0, 8)\n    led.plot_brightness(4, 1, 8)\n    led.plot_brightness(4, 2, 8)\n    led.plot_brightness(4, 3, 8)\n    led.plot_brightness(4, 4, 8)\n\n    if streak >= 1:\n        led.plot_brightness(4, 4, 255)\n    if streak >= 2:\n        led.plot_brightness(4, 3, 255)\n    if streak >= 3:\n        led.plot_brightness(4, 2, 255)\n    if streak >= 4:\n        led.plot_brightness(4, 1, 255)\n    if streak >= 5:\n        led.plot_brightness(4, 0, 255)\n\n\ndef row_111(y, offset_x):\n    led.plot_brightness(offset_x, y, 255)\n    led.plot_brightness(offset_x + 1, y, 255)\n    led.plot_brightness(offset_x + 2, y, 255)\n\n\ndef row_101(y, offset_x):\n    led.plot_brightness(offset_x, y, 255)\n    led.plot_brightness(offset_x + 2, y, 255)\n\n\ndef row_010(y, offset_x):\n    led.plot_brightness(offset_x + 1, y, 255)\n\n\ndef row_110(y, offset_x):\n    led.plot_brightness(offset_x, y, 255)\n    led.plot_brightness(offset_x + 1, y, 255)\n\n\ndef row_001(y, offset_x):\n    led.plot_brightness(offset_x + 2, y, 255)\n\n\ndef row_100(y, offset_x):\n    led.plot_brightness(offset_x, y, 255)\n\n\ndef draw_digit_at(number, offset_x):\n    if number == 0:\n        row_111(0, offset_x)\n        row_101(1, offset_x)\n        row_101(2, offset_x)\n        row_101(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 1:\n        row_010(0, offset_x)\n        row_110(1, offset_x)\n        row_010(2, offset_x)\n        row_010(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 2:\n        row_111(0, offset_x)\n        row_001(1, offset_x)\n        row_111(2, offset_x)\n        row_100(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 3:\n        row_111(0, offset_x)\n        row_001(1, offset_x)\n        row_111(2, offset_x)\n        row_001(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 4:\n        row_101(0, offset_x)\n        row_101(1, offset_x)\n        row_111(2, offset_x)\n        row_001(3, offset_x)\n        row_001(4, offset_x)\n    elif number == 5:\n        row_111(0, offset_x)\n        row_100(1, offset_x)\n        row_111(2, offset_x)\n        row_001(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 6:\n        row_111(0, offset_x)\n        row_100(1, offset_x)\n        row_111(2, offset_x)\n        row_101(3, offset_x)\n        row_111(4, offset_x)\n    elif number == 7:\n        row_111(0, offset_x)\n        row_001(1, offset_x)\n        row_010(2, offset_x)\n        row_010(3, offset_x)\n        row_010(4, offset_x)\n    elif number == 8:\n        row_111(0, offset_x)\n        row_101(1, offset_x)\n        row_111(2, offset_x)\n        row_101(3, offset_x)\n        row_111(4, offset_x)\n    else:\n        row_111(0, offset_x)\n        row_101(1, offset_x)\n        row_111(2, offset_x)\n        row_001(3, offset_x)\n        row_111(4, offset_x)\n\n\ndef draw_left_one_column():\n    led.plot_brightness(0, 0, 255)\n    led.plot_brightness(0, 1, 255)\n    led.plot_brightness(0, 2, 255)\n    led.plot_brightness(0, 3, 255)\n    led.plot_brightness(0, 4, 255)\n\n\ndef draw_guess():\n    basic.clear_screen()\n\n    if guess < 10:\n        draw_digit_at(guess, 1)\n        draw_attempts_left()\n        draw_streak_right()\n    else:\n        draw_left_one_column()\n        draw_digit_at(guess - 10, 1)\n        draw_attempts_right()\n\n\ndef pulse_guess():\n    draw_guess()\n    basic.pause(70)\n    basic.clear_screen()\n    basic.pause(45)\n    draw_guess()\n    basic.pause(70)\n\n\ndef edge_bump():\n    basic.clear_screen()\n    basic.pause(60)\n    draw_guess()\n    basic.pause(70)\n    basic.clear_screen()\n    basic.pause(60)\n    draw_guess()\n\n\ndef success_flash():\n    basic.show_icon(IconNames.YES)\n    basic.pause(180)\n    basic.show_leds(\"\"\"\n        . . # . .\n        . # . # .\n        # . # . #\n        . # . # .\n        . . # . .\n        \"\"\")\n    basic.pause(130)\n    basic.show_icon(IconNames.DIAMOND)\n    basic.pause(130)\n    basic.show_icon(IconNames.SMALL_DIAMOND)\n    basic.pause(90)\n    basic.show_icon(IconNames.DIAMOND)\n    basic.pause(130)\n    basic.show_string(\"+\")\n    basic.show_number(points)\n\n\ndef miss_flash():\n    basic.show_icon(IconNames.SAD)\n    basic.pause(450)\n    basic.show_string(\"ANS\")\n    basic.show_number(target)\n\n\ndef unlock_flash():\n    basic.show_string(\"LVL2\")\n    basic.show_leds(\"\"\"\n        # # # # .\n        # # . # .\n        # # # # .\n        # . . # .\n        # # # # .\n        \"\"\")\n    basic.pause(180)\n    basic.show_leds(\"\"\"\n        # # # # .\n        # # . # .\n        # # . # .\n        # # . # .\n        # # # # .\n        \"\"\")\n    basic.pause(180)\n    basic.show_leds(\"\"\"\n        # # # # .\n        # # . # .\n        # # # # .\n        # . . # .\n        # # # # .\n        \"\"\")\n    basic.pause(180)\n    basic.show_string(\"0-19\")\n\n\ndef show_higher():\n    basic.show_arrow(ArrowNames.NORTH)\n    basic.pause(320)\n\n\ndef show_lower():\n    basic.show_arrow(ArrowNames.SOUTH)\n    basic.pause(320)\n\n\ndef show_status():\n    basic.show_string(\"S\")\n    basic.show_number(score)\n    basic.show_string(\"X\")\n    basic.show_number(streak)\n\n\ndef intro():\n    basic.show_string(\"GUESS\")\n    basic.show_leds(\"\"\"\n        . # # # .\n        # . . . #\n        . . # . .\n        . . . . .\n        . . # . .\n        \"\"\")\n    basic.pause(450)\n    basic.show_string(\"A- B+ AB=OK\")\n    basic.show_string(\"80PTS=0-19\")\n\n\ndef start_round():\n    global guess, target, last_target, attempts_left, max_guess\n\n    if range_unlocked:\n        max_guess = 19\n        guess = 10\n    else:\n        max_guess = 9\n        guess = 5\n\n    target = randint(0, max_guess)\n\n    if target == last_target:\n        target = target + 1\n        if target > max_guess:\n            target = 0\n\n    last_target = target\n    attempts_left = 4\n    draw_guess()\n\n\ndef submit_guess():\n    global score, streak, best_score, best_streak, points\n    global attempts_left, range_unlocked\n\n    if guess == target:\n        points = 10 + attempts_left * 2 + streak * 3\n        score = score + points\n        streak = streak + 1\n\n        if score > best_score:\n            best_score = score\n        if streak > best_streak:\n            best_streak = streak\n\n        success_flash()\n\n        if range_unlocked == False:\n            if score >= 80:\n                range_unlocked = True\n                unlock_flash()\n\n        if streak >= 3:\n            show_status()\n\n        start_round()\n    else:\n        attempts_left = attempts_left - 1\n\n        if attempts_left <= 0:\n            streak = 0\n            miss_flash()\n            start_round()\n        else:\n            if guess < target:\n                show_higher()\n            else:\n                show_lower()\n            draw_guess()\n\n\ndef change_guess(amount):\n    global guess\n\n    if amount > 0:\n        if guess < max_guess:\n            guess = guess + 1\n            pulse_guess()\n        else:\n            edge_bump()\n    else:\n        if guess > 0:\n            guess = guess - 1\n            pulse_guess()\n        else:\n            edge_bump()\n\n\ndef game_tick():\n    if input.button_is_pressed(Button.AB):\n        wait_for_release()\n        submit_guess()\n    elif input.button_is_pressed(Button.B):\n        wait_for_release()\n        change_guess(1)\n    elif input.button_is_pressed(Button.A):\n        wait_for_release()\n        change_guess(-1)\n\n    basic.pause(25)\n\n\nintro()\nstart_round()\nbasic.forever(game_tick)\n","pxt.json":"{\n    \"name\": \"test\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1783135509839,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"/mQyD$^Pg}VK]Ws6Ly]H\">guess</variable><variable id=\"c@@RV/0e8x-/]R/