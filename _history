mber):\n    basic.show_icon(IconNames.SKULL)\n    basic.pause(800)\n    basic.show_string(\"SCORE \" + (\"\" + str(score)))\n    basic.show_arrow(ArrowNames.WEST)\n    wait_for_button()\ndef wait_for_button():\n    while not (input.button_is_pressed(Button.A) or input.button_is_pressed(Button.B)):\n        basic.pause(40)\n    while input.button_is_pressed(Button.A) or input.button_is_pressed(Button.B):\n        basic.pause(40)\ndef play():\n    global dino_y2, obstacle_x2, obstacle_height2, obstacle_gap, delay, jump_velocity, score3\n    dino_y2 = DINO_GROUND_Y\n    obstacle_x2 = -1\n    obstacle_height2 = 1\n    obstacle_gap = 3\n    delay = 230\n    while True:\n        on_ground = dino_y2 == DINO_GROUND_Y\n        if input.button_is_pressed(Button.A) and on_ground:\n            jump_velocity = -2\n        if input.button_is_pressed(Button.B) and on_ground:\n            jump_velocity = -3\n        if jump_velocity != 0 or not (on_ground):\n            dino_y2 += jump_velocity\n            jump_velocity += 1\n            if dino_y2 < 0:\n                dino_y2 = 0\n            if dino_y2 >= DINO_GROUND_Y:\n                dino_y2 = DINO_GROUND_Y\n                jump_velocity = 0\n        if obstacle_x2 >= 0:\n            obstacle_x2 += 0 - 1\n        else:\n            obstacle_gap += 0 - 1\n            if obstacle_gap <= 0:\n                obstacle_x2 = 4\n                obstacle_height2 = randint(1, 2)\n                obstacle_gap = randint(3, 6)\n        if obstacle_x2 == DINO_X and dino_y2 >= DINO_GROUND_Y - obstacle_height2 + 1:\n            draw_game(dino_y2, obstacle_x2, obstacle_height2, score3)\n            basic.pause(250)\n            return score3\n        draw_game(dino_y2, obstacle_x2, obstacle_height2, score3)\n        score3 += 1\n        if score3 % 15 == 0 and delay > 90:\n            delay += 0 - 10\n        basic.pause(delay)\ndef draw_game(dino_y: number, obstacle_x: number, obstacle_height: number, score2: number):\n    basic.clear_screen()\n    for x in range(5):\n        led.plot_brightness(x, GROUND_Y, DIM)\n    if 0 <= obstacle_x and obstacle_x <= 4:\n        led.plot_brightness(obstacle_x, DINO_GROUND_Y, BRIGHT)\n        if obstacle_height == 2:\n            led.plot_brightness(obstacle_x, DINO_GROUND_Y - 1, BRIGHT)\n    led.plot_brightness(DINO_X, dino_y, BRIGHT)\n    if score2 > 0 and score2 % 10 == 0:\n        led.plot_brightness(4, 0, DIM)\nscore3 = 0\njump_velocity = 0\ndelay = 0\nobstacle_gap = 0\nobstacle_height2 = 0\nobstacle_x2 = 0\ndino_y2 = 0\nDIM = 0\nBRIGHT = 0\nDINO_GROUND_Y = 0\nGROUND_Y = 0\nDINO_X = 0\nDINO_X = 1\nGROUND_Y = 4\nDINO_GROUND_Y = 3\nBRIGHT = 255\nDIM = 35\nwhile True:\n    show_start()\n    final_score = play()\n    show_game_over(final_score)","pxt.json":"{\n    \"name\": \"test\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1783133694883,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"BvHR^3cpF9BQSRKX^=Lt\">attempts_left</variable><variable id=\"G6D64Yar|P.lB[Mt,b0l\">streak</variable><variable id=\"?F8^5(D0KnY|YB4Yr4W%\">guess</variable><variable id=\"VQ4c[MBeUP.wMKGGJ.(E\">points</variable><variable id=\"R+4LsdbrnR@}cAH#rIyY\">target</variable><variable id=\"c9Up`y/reX{y|PE~ZY1f\">score</variable><variable id=\"$XnCTL8]k,NRj`@pygE{\">range_unlocked</variable><variable id=\"63_l~S-_Earlz55fm$nE\">max_guess</variable><variable id=\"0froiCi),lH*^;;xLwzG\">last_target</variable><variable id=\"q5@zc$h*4F7xrG4:vRWX\">best_score</variable><variable id=\"DaQK(Ij#?o,B);Kcw0`f\">best_streak</variable></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"><statement name=\"HANDLER\"><block type=\"variables_se